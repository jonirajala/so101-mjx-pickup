diff --git a/src/mw/device/bvh_raycast.cpp b/src/mw/device/bvh_raycast.cpp
index 7c4fa52..5b5fca9 100644
--- a/src/mw/device/bvh_raycast.cpp
+++ b/src/mw/device/bvh_raycast.cpp
@@ -866,14 +866,21 @@ static __device__ FragmentResult computeFragment(
         Vector3 hit_pos = trace_info.rayOrigin +
                           first_hit.depth * trace_info.rayDirection;
 
-        Vector3 acc_color = Vector3{ 0.f, 0.f, 0.f };
-
-        float light_contrib = 0.f;
+        // PHASE-3 / SAPIEN-minimal additive shading, 1:1 with the ManiSkill sensor rasterizer:
+        //   color = albedo * ( ambient_rgb + sum_lights light_color * clamp(N.L,0,1) * shadow )
+        // ambient_rgb is per-world (stored identically on every light -> seed from light[0]);
+        // light_color carries Phase-3 warm/cool tint * per-light intensity. This REPLACES the old
+        // white, non-DR'd `max(0.2, sum clamp(N.L)) * albedo` (fixed floor, no colour/intensity,
+        // MAX-combine instead of additive) -- the one renderer gap that no image-space DR could close.
+        Vector3 acc = (world_info.numLights > 0)
+                          ? world_info.lights[0].ambient
+                          : Vector3{ 0.2f, 0.2f, 0.2f };
 
         for (int i = 0; i < world_info.numLights; ++i) {
             LightDesc desc = world_info.lights[i];
 
             float cutoff = -1.f;
+            float lambert = 0.f;
 
             Vector3 light_dir = -desc.direction;
             if (desc.type == LightDesc::Type::Spotlight) {
@@ -910,15 +917,23 @@ static __device__ FragmentResult computeFragment(
                             }, world_info);
 
                     if (!shadow_hit.hit) {
-                        light_contrib += fminf(fmaxf(first_hit.normal.dot(light_dir), 0.f), 1.f);
+                        lambert = fminf(fmaxf(first_hit.normal.dot(light_dir), 0.f), 1.f);
                     }
                 }
             } else {
-                light_contrib += fminf(fmaxf(first_hit.normal.dot(light_dir), 0.f), 1.f);
+                lambert = fminf(fmaxf(first_hit.normal.dot(light_dir), 0.f), 1.f);
             }
+
+            // ADDITIVE, colour-weighted contribution (Phase-3 sum of light_color * Lambert).
+            acc = acc + lambert * desc.color;
         }
 
-        acc_color = fmaxf(0.2, light_contrib) * first_hit.color;
+        // Modulate by albedo (component-wise; no Vector3*Vector3 Hadamard operator in madrona math).
+        Vector3 acc_color = {
+            acc.x * first_hit.color.x,
+            acc.y * first_hit.color.y,
+            acc.z * first_hit.color.z,
+        };
         acc_color.x = fminf(1.f, acc_color.x);
         acc_color.y = fminf(1.f, acc_color.y);
         acc_color.z = fminf(1.f, acc_color.z);
