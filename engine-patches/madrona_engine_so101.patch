diff --git a/include/madrona/render/ecs.hpp b/include/madrona/render/ecs.hpp
index 1a4f826..65ca0c0 100644
--- a/include/madrona/render/ecs.hpp
+++ b/include/madrona/render/ecs.hpp
@@ -16,6 +16,14 @@ struct RenderCamera {
     math::Vector3 cameraOffset;
 };
 
+// Per-world override of the camera vertical FOV scale (== 1.0 / tanf(fovy*0.5)).
+// viewTransformUpdate writes this into PerspectiveCameraData every frame so the FOV
+// can be domain-randomized per world (the GPU path otherwise freezes xScale/yScale at
+// construction). A value <= 0 means "keep the RenderCamera-baked fovScale" (safe default).
+struct CameraFovScale {
+    float scale;
+};
+
 // This will be attached to any renderable entity
 struct Renderable {
     Entity renderEntity;
@@ -86,6 +94,14 @@ struct LightDesc {
 
     // Gives ability to turn light on or off.
     bool active;
+
+    // Per-light diffuse colour RGB. Carries Phase-3 warm/cool tint * intensity
+    // (SAPIEN folds intensity into the colour). Default {1,1,1}.
+    math::Vector3 color;
+
+    // Per-world ambient RGB (Phase-3 `ambient_light`). Stored identically on every
+    // light; the shader seeds from light[0]. Default {0.2,0.2,0.2} (the old fixed floor).
+    math::Vector3 ambient;
 };
 
 struct LightDescDirection : math::Vector3 {
@@ -110,6 +126,18 @@ struct LightDescIntensity {
     float intensity;
 };
 
+struct LightDescColor : math::Vector3 {
+    LightDescColor(math::Vector3 v)
+        : Vector3(v)
+    {}
+};
+
+struct LightDescAmbient : math::Vector3 {
+    LightDescAmbient(math::Vector3 v)
+        : Vector3(v)
+    {}
+};
+
 struct LightDescActive {
     bool active;
 };
